generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]
  hiringProfile    HiringProfile?
  candidateProfile CandidateProfile?
  apiKeys          ApiKey[]
  postDrafts       PostDraft[]
  sentOutreach     SentOutreach[]
  stats            UserStats?
  emailThreads     EmailThread[]
  emailMessages    EmailMessage[]
  mailboxSync      MailboxSync?
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model HiringProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  role        String
  compRange   String?
  stack       String?
  location    String?
  pitchBlurb  String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CandidateProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  fullName           String?
  phone              String?
  location           String?
  linkedinUrl        String?
  portfolioUrl       String?
  githubUrl          String?
  currentTitle       String?
  yearsExperience    Int?
  summary            String?  @db.Text
  workExperience     String?  @db.Text
  workExperiences    Json?
  projects           Json?
  certificates       Json?
  education          String?  @db.Text
  skills             String?  @db.Text
  certifications     String?  @db.Text
  resumeFileName     String?
  resumeMimeType     String?
  resumeStorageKey   String?
  resumeFileUrl      String?
  resumeFileSize     Int?
  resumeFileData     Bytes?
  resumeContent      String?  @db.Text
  desiredRoles       String?
  salaryExpectation  String?
  workPreference     String?
  availability       String?
  outreachTone       String?  @default("professional")
  draftLength        String?  @default("medium")
  outreachLanguage   String?  @default("en")
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PostDraft {
  id                  String        @id @default(cuid())
  userId              String
  postId              String
  postUrl             String?
  platform            String
  postText            String        @db.Text
  recipientName       String?
  recipientEmail      String?
  recipientHandle     String?
  recipientProfileUrl String?
  actionMode          String
  subject             String?
  message             String        @db.Text
  draftResponse       Json
  profileVersion      String
  industryTag         String?
  cacheHits           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentOutreach SentOutreach?
  variants     DraftVariant[]

  @@unique([userId, postId])
  @@index([userId, createdAt])
}

model DraftVariant {
  id            String    @id @default(cuid())
  postDraftId   String
  variantIndex  Int
  toneUsed      String
  draftLength   String
  message       String    @db.Text
  subject       String?
  draftResponse Json
  selectedAt    DateTime?
  createdAt     DateTime  @default(now())

  postDraft    PostDraft      @relation(fields: [postDraftId], references: [id], onDelete: Cascade)
  sentOutreach SentOutreach[]

  @@unique([postDraftId, variantIndex])
  @@index([postDraftId])
}

model SentOutreach {
  id                  String    @id @default(cuid())
  userId              String
  postDraftId         String?   @unique
  postId              String
  postUrl             String?
  platform            String
  recipientEmail      String?
  recipientName       String?
  recipientHandle     String?
  recipientProfileUrl String?
  gmailMessageId      String?
  rfcMessageId        String?   // RFC 2822 Message-ID header we injected
  gmailThreadId       String?   // Gmail's native threadId from send response
  subject             String?
  message             String    @db.Text
  actionMode          String
  status              String
  responseReceivedAt  DateTime?
  toneUsed            String?
  draftLengthUsed     String?
  matchScore          Int?
  variantId           String?
  responseSource      String?
  industryTag         String?
  sentAt              DateTime  @default(now())

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  postDraft   PostDraft?    @relation(fields: [postDraftId], references: [id], onDelete: SetNull)
  variant     DraftVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  emailThread EmailThread?

  @@index([variantId])

  @@index([userId, sentAt])
  @@index([postId])
  @@index([rfcMessageId])
  @@index([gmailThreadId])
}

model UserStats {
  id              String   @id @default(cuid())
  userId          String   @unique
  sentToday       Int      @default(0)
  sentThisWeek    Int      @default(0)
  totalSent       Int      @default(0)
  draftsToday     Int      @default(0)
  totalReplied    Int      @default(0)
  repliedThisWeek Int      @default(0)
  replyRate7d     Float?
  lastResetDate   String   // YYYY-MM-DD format
  lastResetWeek   String   // YYYY-Wxx format
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WinningTemplate {
  id           String   @id @default(cuid())
  industryTag  String?
  toneUsed     String?
  excerpt      String   @db.Text
  matchScore   Int?
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([industryTag, isPublished])
}

// ─── Email Threading Engine ───────────────────────────────────────────────────

/// One conversation thread per outreach campaign reply chain.
model EmailThread {
  id               String   @id @default(cuid())
  userId           String
  sentOutreachId   String?  @unique // the originating SentOutreach record
  subject          String?
  participantEmail String?  // the external contact's email address
  lastMessageAt    DateTime @default(now())
  isRead           Boolean  @default(true)  // false when an inbound reply arrives
  messageCount     Int      @default(1)
  createdAt        DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentOutreach SentOutreach? @relation(fields: [sentOutreachId], references: [id], onDelete: SetNull)
  messages     EmailMessage[]

  @@index([userId, lastMessageAt])
  @@index([userId, isRead])
}

/// Individual emails (inbound or outbound) belonging to an EmailThread.
model EmailMessage {
  id               String   @id @default(cuid())
  threadId         String
  userId           String
  direction        String   // "OUTBOUND" | "INBOUND"
  fromAddress      String
  toAddresses      String?  @db.Text // JSON-serialised string[]
  subject          String?
  snippet          String?  @db.Text // first ~300 chars of plain text
  rawBody          String?  @db.Text // full plain-text body
  rfcMessageId     String?  // Message-ID header
  inReplyTo        String?  // In-Reply-To header
  references       String?  @db.Text // References header (space-separated)
  providerMsgId    String?  // Gmail message ID
  providerThreadId String?  // Gmail thread ID
  isRead           Boolean  @default(false)
  receivedAt       DateTime
  createdAt        DateTime @default(now())

  thread EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerMsgId])
  @@index([threadId, receivedAt])
  @@index([rfcMessageId])
  @@index([inReplyTo])
}

/// Per-user sync state for the inbound mailbox sync engine.
model MailboxSync {
  id                    String   @id @default(cuid())
  userId                String   @unique
  provider              String   @default("gmail")
  gmailHistoryId        String?  // last processed Gmail historyId (opaque string)
  encryptedRefreshToken String?  @db.Text // AES-256-GCM encrypted refresh token
  syncError             String?  // last error message, null when healthy
  lastSyncedAt          DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
