{
  "name": "draft-ai",
  "displayName": "Draft AI",
  "version": "0.0.2",
  "description": "AI-powered outreach drafts for X and LinkedIn",
  "author": "Jay",
  "scripts": {
    "dev": "plasmo build --watch",
    "dev:hmr": "plasmo dev",
    "dev:stable": "plasmo build --watch",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "package": "plasmo package"
  },
  "dependencies": {
    "@sentry/browser": "^9.47.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.268",
    "@types/node": "20.14.9",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "autoprefixer": "^10.5.2",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.4",
    "typescript": "5.5.3"
  },
  "manifest": {
    "host_permissions": [
      "*://*.x.com/*",
      "*://*.twitter.com/*",
      "*://*.linkedin.com/*",
      "https://*.vercel.app/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ],
    "permissions": [
      "storage",
      "activeTab",
      "clipboardWrite",
      "tabs",
      "sidePanel"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "browser_specific_settings": {
      "gecko": {
        "id": "draft-ai@recruitable.ai",
        "strict_min_version": "109.0"
      }
    }
  }
}
