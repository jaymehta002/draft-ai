generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]
  hiringProfile    HiringProfile?
  candidateProfile CandidateProfile?
  apiKeys          ApiKey[]
  postDrafts       PostDraft[]
  sentOutreach     SentOutreach[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model HiringProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  role        String
  compRange   String?
  stack       String?
  location    String?
  pitchBlurb  String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CandidateProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  fullName           String?
  phone              String?
  location           String?
  linkedinUrl        String?
  portfolioUrl       String?
  githubUrl          String?
  currentTitle       String?
  yearsExperience    Int?
  summary            String?  @db.Text
  workExperience     String?  @db.Text
  workExperiences    Json?
  projects           Json?
  certificates       Json?
  education          String?  @db.Text
  skills             String?  @db.Text
  certifications     String?  @db.Text
  resumeFileName     String?
  resumeContent      String?  @db.Text
  desiredRoles       String?
  salaryExpectation  String?
  workPreference     String?
  availability       String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PostDraft {
  id                  String        @id @default(cuid())
  userId              String
  postId              String
  postUrl             String?
  platform            String
  postText            String        @db.Text
  recipientName       String?
  recipientEmail      String?
  recipientHandle     String?
  recipientProfileUrl String?
  actionMode          String
  subject             String?
  message             String        @db.Text
  draftResponse       Json
  profileVersion      String
  cacheHits           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentOutreach SentOutreach?

  @@unique([userId, postId])
  @@index([userId, createdAt])
}

model SentOutreach {
  id                  String    @id @default(cuid())
  userId              String
  postDraftId         String?   @unique
  postId              String
  postUrl             String?
  platform            String
  recipientEmail      String?
  recipientName       String?
  recipientHandle     String?
  recipientProfileUrl String?
  gmailMessageId      String?
  subject             String?
  message             String    @db.Text
  actionMode          String
  status              String
  responseReceivedAt  DateTime?
  sentAt              DateTime  @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  postDraft PostDraft? @relation(fields: [postDraftId], references: [id], onDelete: SetNull)

  @@index([userId, sentAt])
  @@index([postId])
}
